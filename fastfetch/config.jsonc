// fastfetch config for the caelestia redesign.
// Custom ASCII logo + module layout per spec (system/kernel/shell/uptime/
// DE-WM/memory/storage/colors), adapted for Arch. Runs on every interactive
// fish shell start (see fish/config.fish).
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        // User-replaceable: the nexus "Wallpaper & style" page saves pasted
        // ASCII art here (state file, seeded from the repo's logo.txt by
        // setup.sh so the repo checkout never gets dirtied)
        "source": "~/.local/state/caelestia/logo.txt",
        "type": "file",
        // ANSI magenta is themed by matugen (primary_fixed_dim) - follows the
        // pink accent in both fixed themes and the wallpaper in dynamic
        "color": {
            "1": "magenta"
        },
        "padding": {
            "top": 1,
            "right": 4
        }
    },
    "display": {
        "separator": "  ",
        "key": {
            "width": 12
        }
    },
    "modules": [
        "break",
        {
            "type": "os",
            "key": "󰣇 system",
            "keyColor": "cyan",
            "format": "{pretty-name}"
        },
        {
            "type": "kernel",
            "key": " kernel",
            "keyColor": "cyan"
        },
        {
            "type": "shell",
            "key": " shell",
            "keyColor": "cyan"
        },
        {
            "type": "uptime",
            "key": " uptime",
            "keyColor": "cyan"
        },
        {
            "type": "wm",
            "key": " de/wm",
            "keyColor": "cyan"
        },
        {
            "type": "memory",
            "key": " memory",
            "keyColor": "cyan"
        },
        {
            "type": "disk",
            "key": "󰋊 storage",
            "keyColor": "cyan",
            "folders": "/"
        },
        "break",
        {
            "type": "colors",
            "paddingLeft": 2,
            "symbol": "circle"
        },
        "break"
    ]
}
