#!/usr/bin/env bash
# caelestia - minimal drop-in replacement for caelestia-cli, backed by matugen.
# Implements only the surface this shell fork actually calls:
#
#   caelestia wallpaper -f <path> [--no-smart]   set wallpaper (+ dynamic scheme)
#   caelestia wallpaper -r [--no-smart]          random wallpaper from the walls dir
#   caelestia wallpaper -p <path> [--no-smart]   print preview scheme json to stdout
#   caelestia scheme set [-m dark|light] [-c <hex>] [-w] [--notify]
#       -m  switch mode and regenerate
#       -c  "pick your own": derive palette from a seed color instead of the wallpaper
#       -w  back to wallpaper-dynamic colors
#   caelestia shell <target> <function> [args...]  -> qs -c caelestia ipc call ...
#
# State (all under XDG dirs, never in the dotfiles repo):
#   wallpaper/path.txt  current wallpaper (watched by the shell)
#   scheme-mode.txt     dark|light
#   scheme-seed.txt     seed hex when in pick-your-own mode (absent = dynamic)
#   scheme.json         the palette the shell watches (schema of Colours.qml)

set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/caelestia"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/caelestia"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
WALLS_DIR="${CAELESTIA_WALLS_DIR:-$HOME/Pictures/Wallpapers/caelestia}"

PATH_FILE="$STATE_DIR/wallpaper/path.txt"
MODE_FILE="$STATE_DIR/scheme-mode.txt"
SEED_FILE="$STATE_DIR/scheme-seed.txt"
SCHEME_FILE="$STATE_DIR/scheme.json"
STAGING_FILE="$CACHE_DIR/scheme.staging.json"
PREVIEW_FILE="$CACHE_DIR/scheme.preview.json"
HYPR_SCHEME="$CONFIG_DIR/hypr/scheme/current.lua"

# Three fixed themes (see the vault Decisions entry): Dark and Light both pin
# the accent to the project pink; Dynamic keeps the wallpaper's accent. matugen
# still generates the container/secondary/tertiary roles from the pink seed, so
# these overrides only touch what has to be exact. Values are hex_stripped
# (no #), matching the scheme templates.
#
# PINK_ACCENT (applied in Dark + Light, i.e. seed "custom" mode): #E39AAE is
# 8.1:1 on the dark bg and pairs with a dark onPrimary (#2E1119, 7.85:1) for
# text on pink fills. NOTE: as accent-coloured TEXT on the cream light bg it is
# only 1.95:1 - it's used for fills (progress bars, active pills, buttons), not
# body text, so this is acceptable; flagged in the vault if it needs deepening.
PINK_ACCENT='{"primary":"e39aae","surfaceTint":"e39aae","onPrimary":"2e1119"}'
# CREAM_NEUTRALS (applied in Light, both fixed + dynamic): warm cream, since
# matugen's light neutrals are seed-tinted. bg #F5F0E5, warm-dark text #33302A
# (11.6:1), muted #7A7466.
CREAM_NEUTRALS='{"background":"f5f0e5","onBackground":"33302a","surface":"f5f0e5","surfaceDim":"e6e0d2","surfaceBright":"fbf7ee","surfaceContainerLowest":"ffffff","surfaceContainerLow":"efe9db","surfaceContainer":"e9e2d1","surfaceContainerHigh":"e3dbc8","surfaceContainerHighest":"ddd4bf","onSurface":"33302a","surfaceVariant":"e7e0d0","onSurfaceVariant":"7a7466","inverseSurface":"33302a","inverseOnSurface":"f5f0e5","outline":"7a7466","outlineVariant":"cfc7b6","shadow":"000000","scrim":"000000"}'

die() {
    echo "caelestia: $*" >&2
    exit 1
}

mode() {
    cat "$MODE_FILE" 2>/dev/null || echo dark
}

# scheme_overrides <name>: the jq object of colour overrides for the current
# theme - cream neutrals when in light mode (fixed or dynamic), plus the fixed
# pink accent in Dark/Light ("custom" seed) mode. Empty object for dynamic-dark,
# so every merge is a no-op there.
scheme_overrides() {
    local parts=()
    [[ "$(mode)" == light ]] && parts+=("$CREAM_NEUTRALS")
    [[ "$1" == custom ]] && parts+=("$PINK_ACCENT")
    if [[ ${#parts[@]} -eq 0 ]]; then
        echo '{}'
    else
        printf '%s\n' "${parts[@]}" | jq -cs 'add'
    fi
}

# finalize_scheme <staging file> <name> [dest]
# Patch metadata (and the fixed-theme colour overrides) into a rendered
# template. With no dest, print to stdout.
finalize_scheme() {
    local staging="$1" name="$2" dest="${3:-}"
    local patched
    patched="$(jq --arg name "$name" --arg mode "$(mode)" \
        --argjson over "$(scheme_overrides "$name")" \
        '.name = $name | .flavour = "" | .mode = $mode | .colours += $over' "$staging")"
    if [[ -n "$dest" ]]; then
        printf '%s\n' "$patched" > "$dest.tmp" && mv "$dest.tmp" "$dest"
    else
        printf '%s\n' "$patched"
    fi
}

# Overwrite the same overridden roles in the matugen-rendered
# hypr/scheme/current.lua so window borders/gaps match the shell (matugen
# renders it with its own seed-tinted colours). Runs whenever the overrides are
# non-empty: pink border in Dark, cream + pink in Light. The key anchor
# (name + "=") keeps `surface` from matching surfaceContainer/Variant/Tint, and
# `primary` from matching primaryContainer/onPrimary.
apply_overrides_to_hypr() {
    [[ -f "$HYPR_SCHEME" ]] || return 0
    local name over key val
    name="$([[ -s "$SEED_FILE" ]] && echo custom || echo dynamic)"
    over="$(scheme_overrides "$name")"
    [[ "$over" == '{}' ]] && return 0
    while IFS=$'\t' read -r key val; do
        sed -i -E "s/^([[:space:]]*${key}[[:space:]]*=[[:space:]]*\")[0-9a-fA-F]+(\")/\1${val}\2/" "$HYPR_SCHEME"
    done < <(printf '%s' "$over" | jq -r 'to_entries[] | "\(.key)\t\(.value)"')
}

# regenerate colors + all templates from current seed or wallpaper
regenerate() {
    if [[ -s "$SEED_FILE" ]]; then
        matugen color hex "#$(cat "$SEED_FILE")" -m "$(mode)"
        finalize_scheme "$STAGING_FILE" custom "$SCHEME_FILE"
    elif [[ -s "$PATH_FILE" ]]; then
        # --source-color-index 0: matugen >= 4.0 otherwise prompts to pick one
        # of several extracted colors, which would hang this non-interactive call
        matugen image "$(cat "$PATH_FILE")" -m "$(mode)" --source-color-index 0
        finalize_scheme "$STAGING_FILE" dynamic "$SCHEME_FILE"
    fi
    apply_overrides_to_hypr
    # hypr/scheme/current.lua changed; hyprland only watches its main config
    [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]] && hyprctl reload >/dev/null 2>&1 || true
}

cmd_wallpaper() {
    mkdir -p "$STATE_DIR/wallpaper" "$CACHE_DIR"

    local action="" target=""
    while (($#)); do
        case "$1" in
        -f)
            action=set
            target="$2"
            shift 2
            ;;
        -r)
            action=random
            shift
            ;;
        -p)
            action=preview
            target="$2"
            shift 2
            ;;
        --no-smart) shift ;; # accepted for compat; mode comes from scheme-mode.txt
        *) die "unknown wallpaper argument: $1" ;;
        esac
    done

    case "$action" in
    set | random)
        if [[ "$action" == random ]]; then
            target="$(find "$WALLS_DIR" -type f \
                \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' \) \
                2>/dev/null | shuf -n1)" || true
            [[ -n "$target" ]] || die "no wallpapers found in $WALLS_DIR"
        fi
        [[ -f "$target" ]] || die "no such file: $target"
        printf '%s' "$target" > "$PATH_FILE" # the shell watches this and draws it
        # pick-your-own mode: wallpaper changes, palette stays seed-derived
        [[ -s "$SEED_FILE" ]] || regenerate
        ;;
    preview)
        [[ -f "$target" ]] || die "no such file: $target"
        matugen -c "$CONFIG_DIR/matugen/preview.toml" image "$target" -m "$(mode)" \
            --source-color-index 0 >/dev/null 2>&1
        finalize_scheme "$PREVIEW_FILE" dynamic
        ;;
    *) die "wallpaper needs one of -f/-r/-p" ;;
    esac
}

cmd_scheme() {
    [[ "${1:-}" == set ]] || die "only 'scheme set' is supported"
    shift
    mkdir -p "$STATE_DIR" "$CACHE_DIR"

    local notify=false
    while (($#)); do
        case "$1" in
        -m)
            case "$2" in dark | light) ;; *) die "mode must be dark or light" ;; esac
            printf '%s' "$2" > "$MODE_FILE"
            shift 2
            ;;
        -c)
            printf '%s' "${2#\#}" > "$SEED_FILE"
            shift 2
            ;;
        -w)
            rm -f "$SEED_FILE"
            shift
            ;;
        --notify)
            notify=true
            shift
            ;;
        *) die "unknown scheme argument: $1" ;;
        esac
    done

    regenerate
    if $notify && command -v notify-send >/dev/null; then
        notify-send -a caelestia -u low "Scheme changed" \
            "$(mode) mode, $([[ -s "$SEED_FILE" ]] && echo "seed #$(cat "$SEED_FILE")" || echo "wallpaper colors")"
    fi
}

case "${1:-}" in
wallpaper)
    shift
    cmd_wallpaper "$@"
    ;;
scheme)
    shift
    cmd_scheme "$@"
    ;;
shell)
    shift
    # `caelestia shell -d` style daemon flags go straight to qs; anything
    # else is an ipc call against the running shell
    if [[ "${1:-}" == -* ]]; then
        exec qs -c caelestia "$@"
    fi
    exec qs -c caelestia ipc call "$@"
    ;;
*)
    die "usage: caelestia {wallpaper|scheme|shell} ... (matugen-backed replacement for caelestia-cli)"
    ;;
esac
